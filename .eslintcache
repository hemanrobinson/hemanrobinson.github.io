[{"/Users/hemanrobinson/Documents/Software/hemanrobinson.github.io/src/index.js":"1","/Users/hemanrobinson/Documents/Software/hemanrobinson.github.io/src/App.js":"2","/Users/hemanrobinson/Documents/Software/hemanrobinson.github.io/src/ReportCard.js":"3"},{"size":258,"mtime":1611332985038,"results":"4","hashOfConfig":"5"},{"size":2115,"mtime":1611923002436,"results":"6","hashOfConfig":"5"},{"size":618,"mtime":1611332985038,"results":"7","hashOfConfig":"5"},{"filePath":"8","messages":"9","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"10"},"y4s8cf",{"filePath":"11","messages":"12","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"13","usedDeprecatedRules":"10"},{"filePath":"14","messages":"15","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"16"},"/Users/hemanrobinson/Documents/Software/hemanrobinson.github.io/src/index.js",[],["17","18"],"/Users/hemanrobinson/Documents/Software/hemanrobinson.github.io/src/App.js",["19"],"import React from 'react';\nimport ReportCard from './ReportCard';\nimport './App.css';\n\n// Application:  A grid of little problems.\nfunction App() {\n    return (\n        <div>\n            <div className=\"Description\">\n                <h2>Heman Robinson</h2>\n                <p>\n                <a href=\"https://www.linkedin.com/in/heman-robinson-953a1223/\">on LinkedIn</a>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;\n                <a href=\"https://github.com/hemanrobinson/hemanrobinson.github.io\">on GitHub</a>\n                </p>\n                <p>\n                My career has been spent designing and developing user interfaces and visualizations for data analysis.\n                </p>\n                <p>\n                These fields have lots of little unsolved problems, and GitHub provides a place to solve them.\n                </p>\n            </div>\n            <div className=\"App\">\n                <ReportCard title=\"Preattentive Symbols\"  href=\"https://hemanrobinson.github.io/preattentive/\"  img=\"symbols.png\"    text=\"Improving Pattern Detection\" />\n                <ReportCard title=\"Zooming Aggregates\"    href=\"https://hemanrobinson.github.io/zoom/\"          img=\"zoom.png\"       text=\"Applying Shneiderman's Mantra\" />\n                <ReportCard title=\"Brushing One Million\"  href=\"https://hemanrobinson.github.io/brush/\"         img=\"brush.png\"      text=\"Scatterplot Brushing Performance\" />\n                <ReportCard title=\"SVG versus CANVAS\"     href=\"https://hemanrobinson.github.io/svg-canvas/\"    img=\"svgcanvas.png\"  text=\"SVG versus Canvas Performance\" />\n            </div>\n            <div className=\"Description\">\n                <br />\n                <br />\n                <br />\n                <h2>Inspiration</h2>\n                <p>\n                    <img src=\"inspiration.jpg\"/>\n                </p>\n                <p>\n                My main influences are Cleveland and Tufte, who emphasize the data and de-emphasize everything else.  Few is expert on usability, particularly of dashboards.\n                </p>\n            </div>\n        </div>\n    );\n}\n\nexport default App;\n","/Users/hemanrobinson/Documents/Software/hemanrobinson.github.io/src/ReportCard.js",[],["20","21"],{"ruleId":"22","replacedBy":"23"},{"ruleId":"24","replacedBy":"25"},{"ruleId":"26","severity":1,"message":"27","line":34,"column":21,"nodeType":"28","endLine":34,"endColumn":49},{"ruleId":"22","replacedBy":"29"},{"ruleId":"24","replacedBy":"30"},"no-native-reassign",["31"],"no-negated-in-lhs",["32"],"jsx-a11y/alt-text","img elements must have an alt prop, either with meaningful text, or an empty string for decorative images.","JSXOpeningElement",["31"],["32"],"no-global-assign","no-unsafe-negation"]